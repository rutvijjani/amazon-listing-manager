# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production

# Database
DATABASE_URL=sqlite:///app.db

# Amazon SP-API Configuration
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Login with Amazon (LWA) OAuth
LWA_CLIENT_ID=amzn1.application-oa2-client....
LWA_CLIENT_SECRET=...

# SP-API Role ARN (for IAM user)
SP_API_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/YourSPAPIRole

# OAuth Redirect URI
AMAZON_REDIRECT_URI=http://localhost:5000/auth/amazon/callback

# Optional: Encryption key for tokens (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=your-encryption-key-here
